{
  "name": "lan-desk",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "tauri": "tauri",
    "build:release": "node -e \"const{execSync:r}=require('child_process');const f=r('node scripts/detect-opus.cjs',{encoding:'utf-8'}).trim();r('npx tauri build'+(f?' -- '+f:''),{stdio:'inherit'})\"",
    "build:release-no-opus": "tauri build",
    "build:universal": "BUILD_UNIVERSAL=true bash scripts/build-macos.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.3",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0"
  }
}
